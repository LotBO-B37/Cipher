---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import SectionHead from "../components/SectionHead.astro";
import EntryCard from "../components/EntryCard.astro";
import { getCollection } from "astro:content";

const entries = (await getCollection("entries")).sort(
  (a, b) => a.data.ref.localeCompare(b.data.ref)
);

const featured = entries.filter((entry) => entry.data.status === "flagship").slice(0, 8);
---

<Base title="The Cipher Archive">
  <Nav />

  <main id="top">
    <Hero />

    <section id="about">
      <SectionHead
        ref="Section 01"
        title="About this project"
        count={`${entries.length} documented entries`}
      />

      <div class="about-body">
        <div class="about-col">
          <p>
            This is the landing page for the Astro version of The Cipher Archive.
            It keeps the archive content structured and documented.
          </p>
        </div>
        <div class="about-col">
          <p>
            Each entry is stored as a content item, so the site can grow without
            editing one giant HTML file.
          </p>
        </div>
      </div>
    </section>

    <section id="archive">
      <SectionHead
        ref="Section 02"
        title="Archive"
        count={`${entries.length} entries`}
      />

      <div class="entries-section">
        {entries.map((entry) => (
          <EntryCard entry={entry.data} open={featured.some((item) => item.id === entry.id)} />
        ))}
      </div>
    </section>
  </main>
</Base>
