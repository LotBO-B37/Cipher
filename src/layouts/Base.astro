---
const {
  title = "The Cipher Archive",
  description = "A structured Astro rebuild of The Cipher archive with documented entries.",
  canonical = "",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Source+Sans+3:wght@300;400;500;600&family=IBM+Plex+Mono:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    <meta name="theme-color" content="#f7f4ef" />
    <style>
      :root {
        --paper: #f7f4ef;
        --paper2: #f0ece4;
        --paper3: #e8e3d9;
        --ink: #1c1c1a;
        --ink2: #3d3d38;
        --ink3: #6b6b62;
        --rule: #d8d3c8;
        --rule2: #c8c2b4;
        --oxblood: #8b2e1a;
        --ox-dim: #b84a30;
        --ox-bg: rgba(139, 46, 26, 0.06);
        --gold: #9a7c3a;
        --gold-bg: rgba(154, 124, 58, 0.06);
        --green-a: #2a5c3a;
        --blue-a: #1e3f6b;
        --violet-a: #4a3870;
        --font-head: "Playfair Display", Georgia, serif;
        --font-body: "Source Sans 3", system-ui, sans-serif;
        --font-mono: "IBM Plex Mono", Courier New, monospace;
        --max: 1280px;
        --gap: 2.5rem;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: var(--font-body);
        font-size: 17px;
        line-height: 1.75;
        -webkit-font-smoothing: antialiased;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      button,
      input,
      textarea,
      select {
        font: inherit;
      }

      .wrap {
        max-width: var(--max);
        margin: 0 auto;
      }

      .mono {
        font-family: var(--font-mono);
      }

      .label,
      .ox-label {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .label {
        color: var(--ink3);
      }

      .ox-label {
        color: var(--oxblood);
      }

      main {
        display: block;
      }
    </style>
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
